{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TkSpeed",
  "version": "0.1.0",
  "identifier": "com.tkspeed.app",
  "build": {
    "frontendDist": "../apps/desktop/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev --prefix apps/desktop",
    "beforeBuildCommand": "npm run build --prefix apps/desktop"
  },
  "app": {
    "windows": [
      {
        "title": "TkSpeed",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 680,
        "decorations": false,
        "transparent": true,
        "theme": "Dark",
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'",
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "TkSpeed",
    "copyright": "© 2026 TkSpeed",
    "category": "Utility",
    "shortDescription": "Plataforma de performance para Windows",
    "longDescription": "TkSpeed — análise, monitoramento e otimização de performance com evidência (benchmark) e rollback automático. Cada otimização é medida e mantida somente se houver ganho comprovado.",
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "languages": ["PortugueseBR", "English"]
      }
    }
  },
  "plugins": {}
}
